<UserControl x:Class="GreaseMate.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel Margin="10">

            <TextBox Text="{Binding Vin}" />
            <TextBox Text="{Binding Make}" />
            <TextBox Text="{Binding Model}" />

            <Button Content="Add Vehicle"
            Click="AddVehicle_Click"/>

            <ListBox ItemsSource="{Binding Vehicles}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Make}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </StackPanel>
    </Grid>

</UserControl>